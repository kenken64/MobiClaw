# Port for the web server
PORT=3000

# Path to adb executable (optional - auto-detected if not set)
# ADB_PATH=C:\platform-tools\adb.exe

# AI Agent - set ONE of these API keys (priority: Gemini > OpenAI > Anthropic):
#
# GEMINI_API_KEY=...               # Best for Android UI (Google makes Android)
# GEMINI_MODEL=gemini-2.5-flash    # default: fast, vision, cheap
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o              # default: gpt-4o (best vision)
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Scrcpy H.264 settings
# SCRCPY_MAX_SIZE=1280       # Max dimension (0 = no limit)
# SCRCPY_BITRATE=8000000     # Video bitrate in bps (8Mbps default)
# SCRCPY_MAX_FPS=60          # Max frames per second
